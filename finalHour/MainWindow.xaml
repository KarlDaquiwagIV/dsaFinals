<Window x:Class="finalHour.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:finalHour"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Title="MainWindow" Height="650" Width="900">


    <StackPanel Margin="10">

        <!-- AVAILABLE ITEMS -->
        <Label Content="Available Products" FontWeight="Bold" FontSize="14"/>

        <DataGrid x:Name="ProductsGrid"
           Height="200"
           AutoGenerateColumns="False"
           IsReadOnly="True"
           SelectionMode="Single"
           CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Product ID"   Binding="{Binding ProductId}"   Width="100"/>
                <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}"  Width="*"/>
                <DataGridTextColumn Header="Description"  Binding="{Binding Description}"  Width="*"/>
                <DataGridTextColumn Header="Price"        Binding="{Binding PriceDisplay}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- INPUT FIELD FOR AVAILABLE ITEMS -->

        <WrapPanel Margin="0,10,0,0">
            <Label Content="Product ID"/>
            <TextBox x:Name="TxtProductId" Width="100" Margin="0,0,10,0"/>

            <Label Content="Product Name:"/>
            <TextBox x:Name="TxtProductName" Width="150" Margin="0,0,10,0"/>

            <Label Content="Description:"/>
            <TextBox x:Name="TxtDescription" Width="150" Margin="0,0,10,0"/>

            <Label Content="Price:"/>
            <TextBox x:Name="TxtPrice" Width="80" Margin="0,0,10,0"/>
        </WrapPanel>

        <!-- BUTTONS FOR AVAILABLE ITEMS -->

        <WrapPanel Margin="0,8,0,0">
            <Button Content="Clear" Width="80" Margin="0,0,8,0" Click="Clear_Click"/>
            <Button Content="Remove" Width="80" Margin="0,0,8,0" Click="Remove_Click"/>
            <Button Content="Add to cart" Width="100" Click="AddToCart_Click"/>
            <Button Content="Add" Width="80" Margin="8,0,0,0" Click="Add_Click"/>
        </WrapPanel>
       


        <!-- SHOPPING CART -->
        <Label Content="Shopping Cart" FontWeight="Bold" FontSize="14" Margin="0,16,0,0"/>

        <DataGrid x:Name="CartGrid"
                  Height="200" 
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Product ID"   Binding="{Binding ProductId}"   Width="100"/>
                <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}"  Width="*"/>
                <DataGridTextColumn Header="Description"  Binding="{Binding Description}"  Width="*"/>
                <DataGridTextColumn Header="Price"        Binding="{Binding PriceDisplay}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Content="Remove from cart" Width="120" Margin="0,8,0,0" HorizontalAlignment="Right" Click="RemoveFromCart_Click"/>

    </StackPanel>
</Window>
